    type: "Art",
    image: "https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=400&auto=format&fit=crop"
  },
  {
    id: "vip-jazz-001",
    name: "VIP Table - Jazz Lounge",
    description: "Mesa reservada para 4 personas con botella.",
    price: 300,
    initialStock: 4,
    type: "VIP",
    image: "https://images.unsplash.com/photo-1415201364774-f6f0bb35f28f?q=80&w=400&auto=format&fit=crop"
  },
  {
    id: "fest-002",
    name: "Galactic Pop Festival",
    description: "Los mayores hits del pop internacional.",
    price: 80,
