    description: "Techno industrial en un bunker secreto.",
    price: 40,
    initialStock: 80,
    type: "Club",
    image: "https://images.unsplash.com/photo-1557672172-298e090bd0f1?q=80&w=400&auto=format&fit=crop"
  },
  {
    id: "chill-001",
    name: "Sunset Chill Session",
    description: "Música ambient al atardecer en la azotea.",
    price: 25,
    initialStock: 50,
    type: "Chill",
    image: "https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?q=80&w=400&auto=format&fit=crop"
  },
  {
    id: "art-001",
    name: "Digital Art Gallery Pass",
    description: "Acceso a la exposición inmersiva.",
    price: 20,
