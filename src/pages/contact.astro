---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/islands/ContactForm";

---

<Layout 
  title="Contacto | AstroTickets"
  description="Envíanos tus preguntas y sugerencias. Estamos aquí para ayudarte en AstroTickets."
  ogTitle="Contacto AstroTickets"
  ogDescription="Envíanos tus preguntas y sugerencias. Estamos aquí para ayudarte en AstroTickets."
  ogImage="/social_preview.jpg"
>
  <div class="relative min-h-[90vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-0 left-1/2 w-full -translate-x-1/2 h-full z-0 pointer-events-none opacity-30">
        <div class="absolute top-20 left-10 w-72 h-72 bg-primary rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
        <div class="absolute top-20 right-10 w-72 h-72 bg-secondary rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-8 left-20 w-72 h-72 bg-accent rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-4000"></div>
    </div>

    <div class="max-w-7xl w-full relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
      <!-- Left Column: Info -->
      <div class="space-y-8 animate-in fade-in slide-in-from-left duration-700 order-2 lg:order-1">
        <div>
            <h2 class="text-lg font-semibold text-primary tracking-wide uppercase mb-2">Ponte en contacto</h2>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 leading-tight">Hablemos de tu próxima <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">experiencia</span>.</h1>
            <p class="text-lg md:text-xl text-base-content/70 max-w-lg">
                ¿Tienes alguna duda sobre un evento? ¿Quieres organizar uno con nosotros? Estamos aquí para escucharte.
            </p>
        </div>

        <div class="space-y-6">
            <div class="flex items-start space-x-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-base-200 flex items-center justify-center text-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold">Oficinas Centrales</h3>
                    <p class="text-base-content/70">Av. de la Tecnología 123<br/>Silicon Valley, CA 94025</p>
                </div>
            </div>

            <div class="flex items-start space-x-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-base-200 flex items-center justify-center text-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold">Email</h3>
                    <p class="text-base-content/70">hola@astrotickets.com<br/>soporte@astrotickets.com</p>
                </div>
            </div>

            <div class="flex items-start space-x-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-base-200 flex items-center justify-center text-accent">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.05 12.05 0 0 0 .57 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.03 12.03 0 0 0 2.81.57A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold">Teléfono</h3>
                    <p class="text-base-content/70">+1 (555) 123-4567<br/>Lunes a Viernes, 9am - 6pm</p>
                </div>
            </div>
        </div>
      </div>

      <!-- Right Column: Form Island -->
      <div class="relative animate-in fade-in slide-in-from-right duration-700 delay-200 order-1 lg:order-2">
        <div class="absolute -inset-1 bg-gradient-to-r from-primary to-secondary rounded-2xl blur opacity-30"></div>
        <div class="relative bg-base-100/50 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl p-8 md:p-12">
            <ContactForm client:load />
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
    @keyframes blob {
        0% { transform: translate(0px, 0px) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
        100% { transform: translate(0px, 0px) scale(1); }
    }
    .animate-blob {
        animation: blob 7s infinite;
    }
    .animation-delay-2000 {
        animation-delay: 2s;
    }
    .animation-delay-4000 {
        animation-delay: 4s;
    }
</style>